{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2024"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "electron",
    "outDir": "dist-electron",
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["electron/main.ts"]
}
