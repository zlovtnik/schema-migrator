{
  "name": "schema-migrator-ui",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop and web client for Bedrock Schema Migrator.",
  "author": "SSL Proxy",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "electron:build": "bun run build && bun run electron:build-main && electron-builder",
    "electron:build-main": "tsc -p tsconfig.electron.json && tsc -p tsconfig.electron-preload.json",
    "electron:dev": "bun run electron:build-main && node scripts/electron-dev.mjs",
    "electron:pack": "bun run build && bun run electron:build-main && electron-builder --dir",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"vite.config.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\" \"vite.config.ts\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^3.10.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.62.8",
    "@tanstack/react-virtual": "^3.11.2",
    "keycloak-js": "^26.2.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^6.29.0",
    "shiki": "^1.24.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.10.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.sslproxy.schema-migrator",
    "productName": "Bedrock Schema Migrator",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/main.js",
      "dist-electron/main.js.map",
      "dist-electron-preload/**",
      "package.json",
      "!node_modules/**"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
